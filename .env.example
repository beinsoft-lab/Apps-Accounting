# ─── MySQL Configuration ───────────────────────────────────────────────────────
# Root password — used only by MySQL healthcheck. Never exposed to app.
MYSQL_ROOT_PASSWORD=changeme_root_strong_password

# Database name
MYSQL_DATABASE=beinsoft_accounting

# App-level user (used by Next.js/Prisma). Separate from root.
MYSQL_USER=beinsoft
MYSQL_PASSWORD=changeme_app_strong_password

# ─── Prisma / Next.js ─────────────────────────────────────────────────────────
# DATABASE_URL is constructed from the vars above in docker-compose.yml.
# For local development ONLY (outside Docker), set it directly:
# DATABASE_URL="mysql://beinsoft:changeme_app_strong_password@localhost:3306/beinsoft_accounting"
